# Java .gitignore

# Compiled class files
*.class

# Log files
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs
hs_err_pid*
replay_pid*

# Build output directories
out/
build/
target/

# IDE files — IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# IDE files — Eclipse
.classpath
.project
.settings/
bin/

# IDE files — NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# IDE files — VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
